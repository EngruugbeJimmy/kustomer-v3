PORT=5000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/kustomer_v5?appName=Cluster0
JWT_SECRET=your_jwt_secret
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:5000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_key

# Termii (SMS)
TERMII_API_KEY=your_termii_key
TERMII_SENDER_ID=Kustomer

# Resend (Email)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=hello@kustomer.app

# Anthropic (AI SEO + social posts)
ANTHROPIC_API_KEY=sk-ant-your_key

# Google / YouTube OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/youtube/oauth/callback

# ElevenLabs (optional premium voiceover — falls back to Google TTS if absent)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── SECURITY CHECKLIST ──────────────────────────────────────────
# Before going live, verify:
# [ ] JWT_SECRET is at least 32 random characters
# [ ] MONGODB_URI password has no special characters like @ # $ %
# [ ] NODE_ENV=production (never development in production)
# [ ] FRONTEND_URL is your exact Vercel URL (no trailing slash)
# [ ] All API keys are test keys until you verify everything works
# [ ] MongoDB Atlas Network Access allows 0.0.0.0/0
# [ ] Never commit .env to GitHub — .gitignore covers this

# Facebook / Meta (for social page management and boosting)
FACEBOOK_APP_ID      = your_facebook_app_id
FACEBOOK_APP_SECRET  = your_facebook_app_secret
